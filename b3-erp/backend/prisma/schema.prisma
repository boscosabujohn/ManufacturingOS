  challanNumber       String?
  challanDate         DateTime?
  remarks             String?
  companyId           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([employeeId, periodMonth, periodYear, companyId])
  @@map("payroll_esi_contributions")
}

// TDS Deduction Records
