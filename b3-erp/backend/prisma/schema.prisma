  requiresDocumentation Boolean @default(true)
  documentTypes       String[]
  templateUrl         String?

  // Notifications
  reminderDays        Int[]    // Days before due date to send reminders
  escalationDays      Int?     // Days after due date to escalate
  escalateTo          String?

