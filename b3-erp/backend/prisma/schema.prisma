  employeeId          String
  uanNumber           String?
  pfNumber            String?
  periodMonth         Int
  periodYear          Int

  basicWages          Float    @default(0)
  pfWages             Float    @default(0) // PF applicable wages (capped at 15000)

  employeeContribution Float   @default(0)  // 12% of PF wages to EPF
  employerEPF         Float    @default(0)  // 3.67% of PF wages to EPF
  employerEPS         Float    @default(0)  // 8.33% of PF wages to EPS (capped)
  employerEDLI        Float    @default(0)  // EDLI contribution
  adminCharges        Float    @default(0)  // Admin charges

  totalEmployer       Float    @default(0)
  totalContribution   Float    @default(0)

  vpfEmployee         Float    @default(0)  // Voluntary PF by employee

  status              String   @default("Draft") // Draft, Calculated, Submitted, Paid
  payslipId           String?
  challanNumber       String?
  challanDate         DateTime?
  remarks             String?
  companyId           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([employeeId, periodMonth, periodYear, companyId])
  @@map("payroll_pf_contributions")
}

// ESI Contribution
