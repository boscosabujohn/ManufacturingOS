// =============================================================================
// PERFORMANCE MANAGEMENT MODULE
// =============================================================================

// Goal entity for OKRs and goal management
model Goal {
  id                  String   @id @default(uuid())
  goalCode            String
  title               String
  description         String?

  // Goal type and scope
  goalType            String   // personal, team, department, company
  category            String?  // development, performance, project, strategic

  // Owner and assignment
  ownerId             String   // Employee ID
  ownerName           String
  ownerDepartment     String?

  // For team/department goals
  teamId              String?
  departmentId        String?

  // Hierarchy
  parentGoalId        String?
  parentGoal          Goal?    @relation("GoalHierarchy", fields: [parentGoalId], references: [id])
  childGoals          Goal[]   @relation("GoalHierarchy")

  // Key Results / Metrics
  keyResults          Json?    // Array of key results with targets
  measurementType     String?  // percentage, number, currency, milestone
  targetValue         Decimal?
  currentValue        Decimal? @default(0)
  weightage           Decimal? @default(100)

  // Timeline
  startDate           DateTime
  dueDate             DateTime
  completedDate       DateTime?

  // Status and progress
  status              String   @default("not_started") // not_started, in_progress, on_track, at_risk, completed, cancelled
  progress            Decimal  @default(0)
  priority            String   @default("medium") // low, medium, high, critical

  // Review cycle link
  reviewCycleId       String?

  // Comments and updates
  comments            Json?    // Array of updates/comments
  lastUpdatedBy       String?
  lastUpdatedAt       DateTime?

  companyId           String
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  alignments          GoalAlignment[] @relation("SourceGoal")
  alignedTo           GoalAlignment[] @relation("TargetGoal")

  @@unique([goalCode, companyId])
  @@map("hr_goals")
}

// Goal Alignment - linking goals to each other
model GoalAlignment {
  id                  String   @id @default(uuid())

  sourceGoalId        String
  sourceGoal          Goal     @relation("SourceGoal", fields: [sourceGoalId], references: [id])

  targetGoalId        String
  targetGoal          Goal     @relation("TargetGoal", fields: [targetGoalId], references: [id])

  alignmentType       String   // supports, contributes_to, depends_on, cascaded_from
  weightage           Decimal? @default(100)

  createdBy           String

  companyId           String
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([sourceGoalId, targetGoalId])
  @@map("hr_goal_alignments")
}

// Performance Review Cycle
model PerformanceReviewCycle {
  id                  String   @id @default(uuid())
  cycleCode           String
  cycleName           String
  description         String?

  // Cycle type and period
  cycleType           String   // annual, semi_annual, quarterly, monthly
  fiscalYear          String
  startDate           DateTime
  endDate             DateTime

  // Phases
  goalSettingStart    DateTime?
  goalSettingEnd      DateTime?
  selfAppraisalStart  DateTime?
  selfAppraisalEnd    DateTime?
  managerReviewStart  DateTime?
  managerReviewEnd    DateTime?
  peerReviewStart     DateTime?
  peerReviewEnd       DateTime?
  calibrationStart    DateTime?
  calibrationEnd      DateTime?
  feedbackStart       DateTime?
  feedbackEnd         DateTime?

  // Configuration
  includeSelfAppraisal Boolean @default(true)
  includeManagerReview Boolean @default(true)
  includePeerReview   Boolean  @default(false)
  include360Review    Boolean  @default(false)
  includeGoals        Boolean  @default(true)
  includeCompetencies Boolean  @default(true)

  // Weightages
  goalsWeightage      Decimal? @default(60)
  competenciesWeightage Decimal? @default(40)
  selfAppraisalWeightage Decimal? @default(20)
  managerReviewWeightage Decimal? @default(60)
  peerReviewWeightage Decimal? @default(20)

  // Rating scale
  ratingScale         String   @default("5_point") // 3_point, 4_point, 5_point, custom
  ratingLabels        Json?    // {1: "Needs Improvement", 2: "Meets Expectations", ...}

  // Status
  status              String   @default("draft") // draft, active, in_progress, completed, archived

  companyId           String
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  reviews             PerformanceReview[]

  @@unique([cycleCode, companyId])
  @@map("hr_performance_review_cycles")
}

// Performance Review (individual review records)
model PerformanceReview {
  id                  String   @id @default(uuid())
  reviewCode          String

  // Review cycle link
  reviewCycleId       String
  reviewCycle         PerformanceReviewCycle @relation(fields: [reviewCycleId], references: [id])

  // Employee being reviewed
  employeeId          String
  employeeName        String
  employeeCode        String
  department          String?
  designation         String?
  reportingManagerId  String?
  reportingManagerName String?

  // Review type
  reviewType          String   @default("annual") // probation, confirmation, annual, promotion, special

  // Self Appraisal
  selfAppraisalStatus String   @default("pending") // pending, in_progress, submitted
  selfAppraisalDate   DateTime?
  selfAppraisalComments String?
  selfGoalRatings     Json?    // {goalId: rating, ...}
  selfCompetencyRatings Json?  // {competencyId: rating, ...}
  selfOverallRating   Decimal?
  selfStrengths       String?
  selfImprovementAreas String?

  // Manager Review
  managerReviewStatus String   @default("pending") // pending, in_progress, submitted
  managerReviewDate   DateTime?
  managerComments     String?
  managerGoalRatings  Json?
  managerCompetencyRatings Json?
  managerOverallRating Decimal?
  managerStrengths    String?
  managerImprovementAreas String?
  managerRecommendations String?

  // Peer Reviews (stored as JSON array)
  peerReviews         Json?    // [{reviewerId, reviewerName, ratings, comments, ...}]
  peerReviewStatus    String   @default("not_applicable")

  // Final Rating
  finalRating         Decimal?
  finalRatingLabel    String?
  calibratedRating    Decimal?
  calibrationNotes    String?

  // Status
  status              String   @default("not_started") // not_started, self_appraisal, manager_review, peer_review, calibration, completed
  completedDate       DateTime?

  // Acknowledgment
  employeeAcknowledged Boolean @default(false)
  employeeAcknowledgedAt DateTime?
  employeeAcknowledgmentComments String?

  companyId           String
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  reviewMeetings      ReviewMeeting[]

  @@unique([reviewCode, companyId])
  @@map("hr_performance_reviews")
}

// Review Meeting
model ReviewMeeting {
  id                  String   @id @default(uuid())
  meetingCode         String

  reviewId            String
  review              PerformanceReview @relation(fields: [reviewId], references: [id])

  // Meeting details
