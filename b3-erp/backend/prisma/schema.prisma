// -----------------------------------------
// IT Admin Module
// -----------------------------------------

// User Groups
model UserGroup {
  id          String   @id @default(uuid())
  groupCode   String
  groupName   String
  description String?
  groupType   String   @default("standard") // standard, department, project, security

  parentGroupId String?
  parentGroup   UserGroup?  @relation("GroupHierarchy", fields: [parentGroupId], references: [id])
  childGroups   UserGroup[] @relation("GroupHierarchy")

  permissions   Json?    // Group-level permissions
  isActive      Boolean  @default(true)

  members       UserGroupMember[]

  companyId     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([groupCode, companyId])
  @@map("admin_user_groups")
}

model UserGroupMember {
  id          String   @id @default(uuid())
  groupId     String
  group       UserGroup @relation(fields: [groupId], references: [id])
  userId      String
  isAdmin     Boolean  @default(false) // Group admin
  joinedAt    DateTime @default(now())

  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([groupId, userId])
  @@map("admin_user_group_members")
}

// Roles & Permissions Extensions
model RoleHierarchy {
  id           String   @id @default(uuid())
  roleId       String
  parentRoleId String?
  level        Int      @default(0)
