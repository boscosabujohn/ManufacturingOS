// -----------------------------------------
// System Masters
// -----------------------------------------

model Role {
  id          String       @id @default(uuid())
  roleCode    String
  roleName    String
  category    String       // system, hr, finance, operations, sales, it
  description String?
  isActive    Boolean      @default(true)
  
  permissions Permission[]
  users       User[]
  
  companyId   String
  company     Company      @relation(fields: [companyId], references: [id])
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([roleCode, companyId])
  @@map("sys_roles")
}

model Permission {
  id         String   @id @default(uuid())
  module     String
  canView    Boolean  @default(false)
  canCreate  Boolean  @default(false)
  canEdit    Boolean  @default(false)
  canDelete  Boolean  @default(false)
  canApprove Boolean  @default(false)
  
  roleId     String
  role       Role     @relation(fields: [roleId], references: [id])
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("sys_permissions")
}

model User {
  id                  String    @id @default(uuid())
  username            String    @unique
  password            String
  email               String?
  fullName            String?
  employeeCode        String?
  employeeId          String?   @unique
  employee            Employee? @relation(fields: [employeeId], references: [id])
  
  roleId              String?
  role                Role?     @relation(fields: [roleId], references: [id])
  
  accessLevel         String    @default("employee") // admin, manager, employee, restricted
  isActive            Boolean   @default(true)
  mfaEnabled          Boolean   @default(false)
  accountLocked       Boolean   @default(false)
  loginAttempts       Int       @default(0)
  lastLogin           DateTime?
  passwordLastChanged DateTime?
  
  companyId           String
  company             Company   @relation(fields: [companyId], references: [id])
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@map("sys_users")
}

model DocumentType {
  id                     String   @id @default(uuid())
  typeCode               String
  typeName               String
  category               String   // identity, address, educational, employment, financial, medical, legal, other
  description            String?
  
  isMandatory            Boolean  @default(false)
  isVerificationRequired Boolean  @default(false)
  validityPeriod         Int?     // in months
  renewalRequired        Boolean  @default(false)
  
  allowedFormats         String[]
  maxFileSizeMB          Int      @default(2)
  multipleFilesAllowed   Boolean  @default(false)
  encryptionRequired     Boolean  @default(false)
  
  applicableFor          String   @default("all") // employee, candidate, contractor, dependent, all
  requiredForJoining     Boolean  @default(false)
  requiredForPayroll     Boolean  @default(false)
  
  isActive               Boolean  @default(true)
  companyId              String
  company                Company  @relation(fields: [companyId], references: [id])
  
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([typeCode, companyId])
  @@map("sys_document_types")
}

model NumberSeries {
  id                    String   @id @default(uuid())
  seriesCode            String
  seriesName            String
  documentType          String
  module                String   // sales, purchase, inventory, finance, hr, production, quality
  
  prefix                String?
  suffix                String?
  separator             String   @default("-")
  paddingLength         Int      @default(5)
  includeYear           Boolean  @default(false)
  includeMonth          Boolean  @default(false)
  yearFormat            String   @default("YYYY") // YYYY, YY
  monthFormat           String   @default("MM")   // MM, MMM, MMMM
  
  currentNumber         Int      @default(1)
  startingNumber        Int      @default(1)
  endingNumber          Int      @default(99999)
  incrementBy           Int      @default(1)
  
  resetFrequency        String   @default("never") // never, yearly, monthly, daily
  lastResetDate         DateTime @default(now())
  nextResetDate         DateTime?
  
  allowDuplicates       Boolean  @default(false)
  allowManualEntry      Boolean  @default(false)
  validateSequence      Boolean  @default(true)
  
  defaultSeries         Boolean  @default(false)
  applicableLocations   String[]
  applicableDepartments String[]
  
  isActive              Boolean  @default(true)
  companyId             String
  company               Company  @relation(fields: [companyId], references: [id])
  
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([seriesCode, companyId])
  @@map("sys_number_series")
}

