// Asset Category - Categories for different types of assets
model AssetCategory {
  id                  String   @id @default(uuid())
  categoryCode        String
  categoryName        String
  categoryType        String   // it_assets, office_assets, vehicles, furniture, equipment
  description         String?
  parentCategoryId    String?
  parentCategory      AssetCategory? @relation("AssetCategoryHierarchy", fields: [parentCategoryId], references: [id])
  childCategories     AssetCategory[] @relation("AssetCategoryHierarchy")

  depreciationMethod  String?  // straight_line, declining_balance, sum_of_years
  depreciationRate    Decimal? @db.Decimal(5, 2)
  usefulLifeYears     Int?

  assets              Asset[]

  companyId           String
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([categoryCode, companyId])
  @@map("hr_asset_categories")
}

// Asset - Master table for all company assets
model Asset {
  id                  String   @id @default(uuid())
  assetCode           String
  assetName           String
  assetTag            String?
  serialNumber        String?
  categoryId          String
  category            AssetCategory @relation(fields: [categoryId], references: [id])

  // Asset details
  brand               String?
  model               String?
  specifications      Json?
  description         String?

  // Purchase info
  purchaseDate        DateTime?
  purchasePrice       Decimal? @db.Decimal(15, 2)
  vendorId            String?
  vendorName          String?
  invoiceNumber       String?
  warrantyEndDate     DateTime?

  // Depreciation
  currentValue        Decimal? @db.Decimal(15, 2)
  accumulatedDepreciation Decimal? @db.Decimal(15, 2)
  lastDepreciationDate DateTime?

  // Status
  status              String   @default("available") // available, allocated, maintenance, retired, disposed, lost
  condition           String   @default("good") // new, good, fair, poor, damaged
  location            String?

  // Current allocation
  currentEmployeeId   String?
  currentEmployeeName String?
  currentDepartment   String?
  allocatedDate       DateTime?

  // Insurance
  insuranceNumber     String?
  insuranceProvider   String?
  insuranceExpiry     DateTime?
  insuranceValue      Decimal? @db.Decimal(15, 2)

  // For vehicles
  registrationNumber  String?
  fuelType            String?
  engineNumber        String?
  chassisNumber       String?

  allocations         AssetAllocation[]
  requests            AssetRequest[]
  transfers           AssetTransfer[]
  maintenanceRecords  MaintenanceRequest[]
  stockMovements      AssetStockMovement[]

  companyId           String
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([assetCode, companyId])
  @@map("hr_assets")
}

