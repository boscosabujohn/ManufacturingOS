generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Geographic Masters ---

model Country {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  phoneCode String?
  isActive  Boolean  @default(true)
  states    State[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("core_countries")
}

model State {
  id        String   @id @default(uuid())
  name      String
  countryId String
  country   Country  @relation(fields: [countryId], references: [id])
  isActive  Boolean  @default(true)
  cities    City[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("core_states")
}

model City {
  id        String   @id @default(uuid())
  name      String
  stateId   String
  state     State    @relation(fields: [stateId], references: [id])
  isActive  Boolean  @default(true)
  branches  Branch[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("core_cities")
}

model Territory {
  id            String   @id @default(uuid())
  code          String
  name          String
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([code, companyId])
  @@map("core_territories")
}

// --- Organizational Masters ---

model Company {
  id                 String           @id @default(uuid())
  name               String           @unique
  taxId              String           @unique
  registrationNumber String?
  baseCurrencyId     String?
  baseCurrency       Currency?        @relation("BaseCurrency", fields: [baseCurrencyId], references: [id])
  logoUrl            String?
  address            String?
  email              String?
  phone              String?
  isActive           Boolean          @default(true)
  isEliminationEntity Boolean         @default(false)
  
  branches           Branch[]
  departments        Department[]
  designations       Designation[]
  costCenters        CostCenter[]
  plants             Plant[]
  warehouses         Warehouse[]
  exchangeRates      ExchangeRate[]
  uoms               Uom[]
  uomConversions     UomConversion[]
  itemCategories     ItemCategory[]
  itemGroups         ItemGroup[]
  brands             Brand[]
  hsnSacs            HsnSac[]
  items              Item[]
  barcodes           Barcode[]
  customerCategories CustomerCategory[]
  customers          Customer[]
  vendorCategories   VendorCategory[]
  vendors            Vendor[]
  
  // HR Masters
  employees          Employee[]
  shifts             Shift[]
  holidays           Holiday[]
  
  // Financial Masters
  accounts           Account[]
  bankAccounts       BankAccount[]
  taxes              Tax[]
  paymentTerms       PaymentTerm[]
  priceLists         PriceList[]
  territories        Territory[]
  
  // Manufacturing Masters
  machines           Machine[]
  workCenters        WorkCenter[]
  operations         Operation[]
  routings           Routing[]
  tools              Tool[]
  qualityParameters  QualityParameter[]
  skills             Skill[]
  batches            Batch[]
  
  // Kitchen Manufacturing Masters
  cabinetTypes      CabinetType[]
  kitchenHardware   KitchenHardware[]
  kitchenFinishes   KitchenFinish[]
  materialGrades    MaterialGrade[]
  kitchenLayouts    KitchenLayout[]
  installationTypes InstallationType[]
  kitchenAppliances KitchenAppliance[]
  counterMaterials  CounterMaterial[]

  // System Masters
  roles             Role[]
  users             User[]
  documentTypes     DocumentType[]
  numberSeries      NumberSeries[]
  
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@map("core_companies")
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  cityId    String?
  city      City?    @relation(fields: [cityId], references: [id])
  address   String?
  isActive  Boolean  @default(true)
  
  departments Department[]
  plants      Plant[]
  warehouses  Warehouse[]
  employees   Employee[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("core_branches")
}

model Department {
  id        String   @id @default(uuid())
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  isActive  Boolean  @default(true)
  
  employees Employee[]
  workCenters WorkCenter[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, companyId])
  @@map("core_departments")
}

model Designation {
  id        String   @id @default(uuid())
  code      String
  name      String
  level     Int?
  grade     String?
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  isActive  Boolean  @default(true)
  
  employees Employee[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code, companyId])
  @@map("core_designations")
}

model CostCenter {
  id        String   @id @default(uuid())
  code      String
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  isActive  Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code, companyId])
  @@map("core_cost_centers")
}

model Plant {
  id        String   @id @default(uuid())
  code      String
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  isActive  Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code, companyId])
  @@map("core_plants")
}

model Warehouse {
  id                 String           @id @default(uuid())
  warehouseCode      String           @unique @map("code")
  warehouseName      String           @map("name")
  companyId          String
  company            Company          @relation(fields: [companyId], references: [id])
  branchId           String?
  branch             Branch?          @relation(fields: [branchId], references: [id])
  address            String?
  isActive           Boolean          @default(true)
  
  warehouseType      String           @default("Main Warehouse")
  status             String           @default("Active")
  addressLine1       String?
  addressLine2       String?
  city               String?
  state              String?
  postalCode         String?
  country            String?
  contactPerson      String?
  phone              String?
  email              String?
  totalArea          Decimal?         @db.Decimal(15, 2)
  areaUnit           String?
  storageCapacity    Decimal?         @db.Decimal(15, 2)
  capacityUnit       String?
  currentUtilization Decimal?         @db.Decimal(5, 2)
  parentWarehouseId  String?
  managerId          String?
  managerName        String?
  allowNegativeStock Boolean          @default(true)
  requiresBatchTracking Boolean       @default(false)
  requiresSerialTracking Boolean      @default(false)
  autoReplenishment  Boolean          @default(false)
  temperatureMin     Decimal?         @db.Decimal(5, 2)
  temperatureMax     Decimal?         @db.Decimal(5, 2)
  humidityMin        Decimal?         @db.Decimal(5, 2)
  humidityMax        Decimal?         @db.Decimal(5, 2)
  description        String?
  remarks            String?
  workingHours       Json?
  facilities         Json?
  certifications     Json?
  createdBy          String?
  updatedBy          String?

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([warehouseCode, companyId])
  @@map("core_warehouses")
}

// --- Inventory Models ---

model StockBalance {
  id                String   @id @default(uuid())
  itemId            String
  itemCode          String
  itemName          String
  itemCategory      String?
  itemGroup         String?
  warehouseId       String
  warehouseName     String
  locationId        String?
  locationName      String?
  batchId           String?
  batchNumber       String?
  serialNumberId    String?
  serialNumber      String?
  availableQuantity Decimal  @default(0) @db.Decimal(15, 4)
  reservedQuantity  Decimal  @default(0) @db.Decimal(15, 4)
  inQualityInspection Decimal @default(0) @db.Decimal(15, 4)
  quarantineQuantity Decimal @default(0) @db.Decimal(15, 4)
  damageQuantity    Decimal  @default(0) @db.Decimal(15, 4)
  inTransitQuantity Decimal  @default(0) @db.Decimal(15, 4)
  committedQuantity Decimal  @default(0) @db.Decimal(15, 4)
  uom               String
  totalQuantity     Decimal  @default(0) @db.Decimal(15, 4)
  freeQuantity      Decimal  @default(0) @db.Decimal(15, 4)
  valuationRate     Decimal  @default(0) @db.Decimal(15, 2)
  stockValue        Decimal  @default(0) @db.Decimal(15, 2)
  valuationMethod   String   @default("Weighted Average")
  currency          String   @default("INR")
  reorderLevel      Decimal? @db.Decimal(15, 4)
  reorderQuantity   Decimal? @db.Decimal(15, 4)
  minimumOrderQuantity Decimal? @db.Decimal(15, 4)
  maximumOrderQuantity Decimal? @db.Decimal(15, 4)
  safetyStock       Decimal? @db.Decimal(15, 4)
  belowReorderLevel Boolean  @default(false)
  firstReceiptDate  DateTime? @db.Date
  lastReceiptDate   DateTime? @db.Date
  lastIssueDate     DateTime? @db.Date
  daysInStock       Int?
  daysSinceLastMovement Int?
  isSlowMoving      Boolean  @default(false)
  isNonMoving       Boolean  @default(false)
  isObsolete        Boolean  @default(false)
  isExpired         Boolean  @default(false)
  expiryDate        DateTime? @db.Date
  abcClassification String?
  velocityClassification String?
  lastCycleCountDate String? 
  nextCycleCountDate String? 
  cycleCountFrequency Int     @default(0)
  projectId         String?
  projectName       String?
  costCenterId      String?
  costCenterName    String?
  ownerId           String?
  ownerName         String?
  ownershipType     String   @default("Own Stock")
  lastStockEntryId  String?
  lastStockEntryNumber String?
  lastUpdatedTime   DateTime?
  updatedBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([itemId, warehouseId, locationId])
  @@index([itemId, warehouseId, batchId])
  @@index([itemId, warehouseId])
  @@map("stock_balances")
}

model StockEntry {
  id                String   @id @default(uuid())
  entryNumber       String   @unique
  entryType         String   
  movementDirection String
  postingDate       DateTime @db.Date
  postingTime       DateTime
  status            String   @default("Draft")
  referenceType     String?
  referenceId       String?
  referenceNumber   String?
  fromWarehouseId   String?
  fromWarehouseName String?
  toWarehouseId     String?
  toWarehouseName   String?
  supplierId        String?
  supplierName      String?
  customerId        String?
  customerName      String?
  isPosted          Boolean  @default(false)
  postedAt          DateTime?
  postedBy          String?
  journalEntryId    String?
  totalValue        Decimal  @default(0) @db.Decimal(15, 2)
  currency          String   @default("INR")
  additionalCosts   Decimal  @default(0) @db.Decimal(15, 2)
  costBreakup       Json?
  requiresApproval  Boolean  @default(false)
  approvedBy        String?
  approvedAt        DateTime?
  requiresInspection Boolean @default(false)
  inspectionId      String?
  inspectionStatus  String?
  projectId         String?
  projectName       String?
  costCenterId      String?
  costCenterName    String?
  vehicleNumber     String?
  driverName        String?
  lrNumber          String?
  lrDate            DateTime? @db.Date
  transporterName   String?
  remarks           String?
  attachments       Json?
  createdBy         String?
  updatedBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  lines             StockEntryLine[]

  @@map("stock_entries")
}

model StockEntryLine {
  id                String   @id @default(uuid())
  stockEntryId      String
  stockEntry        StockEntry @relation(fields: [stockEntryId], references: [id], onDelete: Cascade)
  lineNumber        Int
  itemId            String
  itemCode          String
  itemName          String
  description       String?
  quantity          Decimal  @db.Decimal(15, 4)
  uom               String
  conversionFactor  Decimal? @db.Decimal(15, 4)
  stockUom          String?
  stockQuantity     Decimal? @db.Decimal(15, 4)
  fromLocationId    String?
  fromLocationName  String?
  toLocationId      String?
  toLocationName    String?
  batchId           String?
  batchNumber       String?
  serialNumberId    String?
  serialNumber      String?
  rate              Decimal  @default(0) @db.Decimal(15, 2)
  amount            Decimal  @default(0) @db.Decimal(15, 2)
  valuationMethod   String?
  acceptedQuantity  Decimal? @db.Decimal(15, 4)
  rejectedQuantity  Decimal? @db.Decimal(15, 4)
  qualityStatus     String?
  glAccountId       String?
  glAccountName     String?
  sourceDocumentLineId String?
  remarks           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("stock_entry_lines")
}

model ExchangeRate {
  id             String   @id @default(uuid())
  fromCurrencyId String
  fromCurrency   Currency @relation("FromCurrency", fields: [fromCurrencyId], references: [id])
  toCurrencyId   String
  toCurrency     Currency @relation("ToCurrency", fields: [toCurrencyId], references: [id])
  rate           Float
  effectiveDate  DateTime
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id])
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("core_exchange_rates")
}

// --- Foundation Masters ---

model Currency {
  id            String    @id @default(uuid())
  code          String    @unique
  name          String
  symbol        String
  symbolNative  String?
  decimalDigits Int       @default(2)
  rounding      Float     @default(0)
  isActive      Boolean   @default(true)
  
  baseCompanies     Company[] @relation("BaseCurrency")
  fromExchangeRates ExchangeRate[] @relation("FromCurrency")
  toExchangeRates   ExchangeRate[] @relation("ToCurrency")
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("core_currencies")
}

model Uom {
  id        String   @id @default(uuid())
  code      String
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  isActive  Boolean  @default(true)
  
  conversionsFrom UomConversion[] @relation("FromUom")
  conversionsTo   UomConversion[] @relation("ToUom")
  items           Item[]
  workCenters     WorkCenter[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code, companyId])
  @@map("core_uoms")
}

model UomConversion {
  id        String   @id @default(uuid())
  fromUomId String
  fromUom   Uom      @relation("FromUom", fields: [fromUomId], references: [id])
  toUomId   String
  toUom     Uom      @relation("ToUom", fields: [toUomId], references: [id])
  factor    Float
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("core_uom_conversions")
}

model ItemCategory {
  id        String   @id @default(uuid())
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  isActive  Boolean  @default(true)
  
  groups    ItemGroup[]
  items     Item[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, companyId])
  @@map("core_item_categories")
}

model ItemGroup {
  id             String       @id @default(uuid())
  name           String
  categoryId     String
  category       ItemCategory @relation(fields: [categoryId], references: [id])
  companyId      String
  company        Company      @relation(fields: [companyId], references: [id])
  isActive       Boolean      @default(true)
  
  items          Item[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([name, companyId])
  @@map("core_item_groups")
}

model Brand {
  id        String   @id @default(uuid())
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  isActive  Boolean  @default(true)
  items     Item[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, companyId])
  @@map("core_brands")
}

model HsnSac {
  id          String   @id @default(uuid())
  code        String
  description String?
  gstPercentage Float    @default(0)
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  isActive    Boolean  @default(true)
  items       Item[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([code, companyId])
  @@map("core_hsn_sac")
}

model Item {
  id            String       @id @default(uuid())
  code          String
  name          String
  description   String?
  itemType      String       // RAW_MATERIAL, FINISHED_GOODS, etc.
  categoryId    String?
  category      ItemCategory? @relation(fields: [categoryId], references: [id])
  groupId       String?
  group         ItemGroup?    @relation(fields: [groupId], references: [id])
  uomId         String
  uom           Uom           @relation(fields: [uomId], references: [id])
  brandId       String?
  brand         Brand?        @relation(fields: [brandId], references: [id])
  hsnSacId      String?
  hsnSac        HsnSac?       @relation(fields: [hsnSacId], references: [id])
  sku           String?
  purchasePrice Float?       @default(0)
  sellingPrice  Float?       @default(0)
  costPrice     Float?       @default(0)
  minStockLevel Float?       @default(0)
  maxStockLevel Float?       @default(0)
  reorderLevel  Float?       @default(0)
  reorderQuantity Float?     @default(0)
  isStockable   Boolean      @default(true)
  isSellable    Boolean      @default(true)
  isPurchasable Boolean      @default(true)
  companyId     String
  company       Company      @relation(fields: [companyId], references: [id])
  isActive      Boolean      @default(true)
  barcodes      Barcode[]
  routings      Routing[]
  batches       Batch[]
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([code, companyId])
  @@map("core_items")
}

model Barcode {
  id        String   @id @default(uuid())
  code      String
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id])
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  isActive  Boolean  @default(true)
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([code, companyId])
  @@map("core_barcodes")
}

// --- Stakeholder Masters ---

model CustomerCategory {
  id          String   @id @default(uuid())
  code        String
  name        String
  description String?
  color       String?  @default("#3B82F6")
  icon        String?
  level       String?  @default("Primary")
  classification String? @default("Standard")
  status      String   @default("Active")
  
  // Nested JSON fields for consistency with UI
  criteria    Json?    // minRevenue, minOrders, etc.
  benefits    Json?    // discountPercent, creditLimit, etc.
  terms       Json?    // paymentTerms, deliveryPriority, etc.
  targets     Json?    // revenueTarget, growthTarget, etc.
  metrics     Json?    // customerCount, totalRevenue, etc.

  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  
  customers   Customer[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([code, companyId])
  @@map("crm_customer_categories")
}

model Customer {
  id            String   @id @default(uuid())
  customerCode  String
  customerName  String
  customerType  String   @default("business") // individual, business, government
  status        String   @default("active")
  
  categoryId    String?
  category      CustomerCategory? @relation(fields: [categoryId], references: [id])
  
  contactPerson String?
  email         String?
  phone         String?
  mobile        String?
  website       String?

  // Nested JSON fields for consistency with UI
  address       Json?    // line1, city, state, etc.
  billingAddress Json?
  taxInfo       Json?    // taxId, vatNumber, etc.
  creditInfo    Json?    // creditLimit, paymentTerms, etc.
  pricing       Json?    // priceList, discountPercentage, etc.
  salesInfo     Json?    // salesRep, totalSales, etc.

  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([customerCode, companyId])
  @@map("crm_customers")
}

model VendorCategory {
  id          String   @id @default(uuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  
  vendors     Vendor[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, companyId])
  @@map("proc_vendor_categories")
}

model Vendor {
  id            String   @id @default(uuid())
  vendorCode    String
  vendorName    String
  vendorType    String   @default("supplier")
  status        String   @default("active")
  
  categoryId    String?
  category      VendorCategory? @relation(fields: [categoryId], references: [id])
  
  contactPerson String?
  email         String?
  phone         String?
  mobile        String?
  website       String?

  // Nested JSON fields for consistency with UI
  address       Json?
  taxInfo       Json?
  paymentInfo   Json?
  qualifications Json?   // certifications, licenses, etc.
  supplierInfo  Json?   // leadTime, minimumOrderValue, etc.
  performance   Json?   // onTimeDelivery, qualityScore, etc.

  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([vendorCode, companyId])
  @@map("proc_vendors")
}

// --- HR Masters ---

model Employee {
  id              String      @id @default(uuid())
  employeeCode    String
  firstName       String
  lastName        String
  email           String?
  phone           String?
  designationId   String?
  designation     Designation? @relation(fields: [designationId], references: [id])
  departmentId    String?
  department      Department?  @relation(fields: [departmentId], references: [id])
  branchId        String?
  branch          Branch?      @relation(fields: [branchId], references: [id])
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id])
  joiningDate     DateTime?
  status          String       @default("Active") // Active, Inactive, Terminated, Resigned
  isActive        Boolean      @default(true)
  user            User?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([employeeCode, companyId])
  @@map("hr_employees")
}

model Shift {
  id        String   @id @default(uuid())
  code      String
  name      String
  startTime String?  // e.g., "09:00"
  endTime   String?  // e.g., "18:00"
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code, companyId])
  @@map("hr_shifts")
}

model Holiday {
  id          String   @id @default(uuid())
  date        DateTime
  name        String
  holidayType String   @default("Public") // Public, Company
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date, companyId])
  @@map("hr_holidays")
}

// --- Financial Masters ---

model Account {
  id               String   @id @default(uuid())
  accountCode      String
  accountName      String
  parentId         String?
  parent           Account?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children         Account[] @relation("AccountHierarchy")
  level            Int      @default(1)
  accountType      String   // asset, liability, equity, revenue, expense
  accountSubType   String?
  status           String   @default("active")
  description      String?
  isControlAccount Boolean  @default(false)
  allowPosting     Boolean  @default(true)
  currency         String   @default("INR")
  
  // JSON fields for specific settings
  taxConfiguration Json?    // taxable, defaultTaxCode, etc.
  reportingSettings Json?   // includeInBalanceSheet, etc.
  balanceInfo      Json?    // openingBalance, currentBalance, etc.
  restrictions     Json?    // department, costCenter, etc.
  integration      Json?    // bankAccount, externalCode, etc.

  companyId        String
  company          Company  @relation(fields: [companyId], references: [id])

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([accountCode, companyId])
  @@map("fin_accounts")
}

model BankAccount {
  id                String   @id @default(uuid())
  bankName          String
  branchName        String?
