// ============================================================================
// SUPPORT MODULE - Advanced Features
// ============================================================================

model SupportChannel {
  id              String   @id @default(uuid())
  code            String
  name            String
  type            String   // email, phone, chat, social, portal, api
  description     String?

  // Channel Configuration
  isEnabled       Boolean  @default(true)
  priority        Int      @default(5) // Default priority for tickets from this channel
  autoAssign      Boolean  @default(false)
  defaultTeamId   String?
  defaultAgentId  String?

  // Response Settings
  autoResponseEnabled Boolean @default(false)
  autoResponseTemplate String?

  // SLA Override
  slaOverrideId   String?

  // Integration Config (for API/Social channels)
  integrationConfig Json?

  // Metrics
