// =============================================================================
// TRAINING & DEVELOPMENT MODULE
// =============================================================================

// Training Program
model TrainingProgram {
  id                  String   @id @default(uuid())
  programCode         String
  programName         String
  description         String?

  // Program classification
  programType         String   // internal, external, online, blended, on_the_job
  category            String   // technical, soft_skills, compliance, leadership, safety, product
  subCategory         String?

  // Delivery
  deliveryMode        String   // classroom, online, virtual, self_paced, workshop
  language            String   @default("English")

  // Duration
  durationHours       Decimal
  durationDays        Decimal?

  // Capacity
  minParticipants     Int?
  maxParticipants     Int?

  // Prerequisites
  prerequisites       Json?    // [{type, value}]
  targetAudience      Json?    // {departments, designations, skillLevels}

  // Content
  objectives          Json?    // Learning objectives
  curriculum          Json?    // Modules/topics
  materials           Json?    // Required materials
  resourceUrls        String[]

  // Assessment
  hasAssessment       Boolean  @default(false)
  passingScore        Decimal?
  certificationAwarded Boolean @default(false)
  certificationName   String?
  certificationValidity Int?   // months

  // Provider (for external)
  providerId          String?
  providerName        String?
  providerContact     String?

  // Cost
  costPerParticipant  Decimal?
  totalBudget         Decimal?
  currency            String   @default("INR")

  // Status
  status              String   @default("draft") // draft, active, inactive, archived

  companyId           String
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  schedules           TrainingSchedule[]
  enrollments         TrainingEnrollment[]
  feedbacks           TrainingFeedback[]
  assessments         TrainingAssessment[]

  @@unique([programCode, companyId])
  @@map("hr_training_programs")
}

// Training Schedule
model TrainingSchedule {
  id                  String   @id @default(uuid())
  scheduleCode        String

  programId           String
  program             TrainingProgram @relation(fields: [programId], references: [id])

  // Schedule details
  batchName           String?
  startDate           DateTime
  endDate             DateTime
  startTime           String?
  endTime             String?
  timezone            String   @default("Asia/Kolkata")

  // Location
  locationType        String   // physical, virtual, hybrid
  venue               String?
  address             String?
  meetingLink         String?
  meetingId           String?

  // Capacity
  maxParticipants     Int
  registeredCount     Int      @default(0)
  attendedCount       Int      @default(0)
  waitlistCount       Int      @default(0)

  // Trainer
  trainerId           String?
  trainerName         String?
  trainerType         String?  // internal, external
  trainerEmail        String?
  trainerPhone        String?

  // Registration
  registrationStartDate DateTime?
  registrationEndDate DateTime?
  autoConfirm         Boolean  @default(false)
  requiresApproval    Boolean  @default(true)

  // Status
  status              String   @default("scheduled") // scheduled, ongoing, completed, cancelled, postponed

  // Cost tracking
  actualCost          Decimal?
  venueCost           Decimal?
  trainerCost         Decimal?
  materialsCost       Decimal?
  otherCosts          Decimal?

  // Completion
  completionDate      DateTime?
  completionNotes     String?

  companyId           String
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  enrollments         TrainingEnrollment[]
  attendanceRecords   TrainingAttendance[]
  waitlist            TrainingWaitlist[]

  @@unique([scheduleCode, companyId])
  @@map("hr_training_schedules")
}

// Training Enrollment
model TrainingEnrollment {
  id                  String   @id @default(uuid())
  enrollmentCode      String

  programId           String
  program             TrainingProgram @relation(fields: [programId], references: [id])

  scheduleId          String?
  schedule            TrainingSchedule? @relation(fields: [scheduleId], references: [id])

  // Employee
  employeeId          String
  employeeName        String
  employeeCode        String
  department          String?
  designation         String?
  managerId           String?
  managerName         String?

  // Enrollment details
  enrollmentType      String   @default("nominated") // self, nominated, mandatory
  enrollmentDate      DateTime @default(now())
  nominatedBy         String?
  nominatedByName     String?
  priority            String   @default("normal") // low, normal, high, urgent

  // Approval
  approvalStatus      String   @default("pending") // pending, approved, rejected, waitlisted
  approvedById        String?
  approvedByName      String?
  approvedAt          DateTime?
  rejectionReason     String?

  // Status
  status              String   @default("enrolled") // enrolled, in_progress, completed, cancelled, no_show
  completionStatus    String?  // passed, failed, incomplete
  completionDate      DateTime?

  // Assessment
  assessmentScore     Decimal?
  assessmentAttempts  Int      @default(0)
  assessmentPassed    Boolean?

  // Certificate
  certificateIssued   Boolean  @default(false)
  certificateNumber   String?
  certificateUrl      String?
  certificateIssuedAt DateTime?

  // Attendance
  attendancePercent   Decimal?
  totalSessions       Int?
  attendedSessions    Int?

  // Feedback
  feedbackSubmitted   Boolean  @default(false)
  feedbackSubmittedAt DateTime?

  // Notes
  employeeNotes       String?
  managerNotes        String?

  companyId           String
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

