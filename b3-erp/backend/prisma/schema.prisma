}

// IT Admin Module Settings
model ITAdminModuleSettings {
  id                  String   @id @default(uuid())
  companyId           String   @unique

  // User Management
  userPrefix          String   @default("USR")
  groupPrefix         String   @default("GRP")
  defaultAccessLevel  String   @default("employee")
  requireEmailVerification Boolean @default(true)

  // Security
  defaultPasswordPolicyId String?
  sessionTimeoutMinutes Int    @default(480) // 8 hours
  maxConcurrentSessions Int    @default(3)
  enforceIpWhitelist  Boolean  @default(false)

  // Audit
  auditRetentionDays  Int      @default(365)
  loginHistoryDays    Int      @default(90)
  changeLogEnabled    Boolean  @default(true)

  // Database
  autoBackupEnabled   Boolean  @default(true)
  backupFrequency     String   @default("daily") // hourly, daily, weekly
  backupRetentionDays Int      @default(30)

  // Monitoring
  healthCheckInterval Int      @default(5) // Minutes
  alertOnHealthDegraded Boolean @default(true)
  metricsRetentionDays Int     @default(30)

  // Scheduler
  maxConcurrentJobs   Int      @default(5)
  jobTimeoutMinutes   Int      @default(60)

  // Notifications
  adminNotificationEmails String[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("admin_module_settings")
}

// --- Notifications ---

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // 'approval_assigned', 'approval_approved', etc.
  title     String
  message   String
  metadata  Json?    // { approvalId, workflowName, etc. }
  isRead    Boolean  @default(false)
  priority  String   @default("info") // 'info', 'warning', 'urgent'
  actionUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}
