  agenda              String?
  discussionPoints    Json?
  actionItems         Json?
  meetingNotes        String?
  outcomes            String?

  // Completion
  actualDate          DateTime?
  completedBy         String?

  companyId           String
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([meetingCode, companyId])
  @@map("hr_review_meetings")
