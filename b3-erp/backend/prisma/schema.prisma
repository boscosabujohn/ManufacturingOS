generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Geographic Masters ---

model Country {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  phoneCode String?
  isActive  Boolean  @default(true)
  states    State[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("core_countries")
}

model State {
  id        String   @id @default(uuid())
  name      String
  countryId String
  country   Country  @relation(fields: [countryId], references: [id])
  isActive  Boolean  @default(true)
  cities    City[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("core_states")
}

model City {
  id        String   @id @default(uuid())
  name      String
  stateId   String
  state     State    @relation(fields: [stateId], references: [id])
  isActive  Boolean  @default(true)
  branches  Branch[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("core_cities")
}

model Territory {
  id            String   @id @default(uuid())
  code          String
  name          String
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([code, companyId])
  @@map("core_territories")
}

// --- Organizational Masters ---

model Company {
  id                 String           @id @default(uuid())
  name               String           @unique
  taxId              String           @unique
  registrationNumber String?
  baseCurrencyId     String?
  baseCurrency       Currency?        @relation("BaseCurrency", fields: [baseCurrencyId], references: [id])
  logoUrl            String?
  address            String?
  email              String?
  phone              String?
  isActive           Boolean          @default(true)
  isEliminationEntity Boolean         @default(false)
  
  branches           Branch[]
  departments        Department[]
  designations       Designation[]
  costCenters        CostCenter[]
  plants             Plant[]
  warehouses         Warehouse[]
  exchangeRates      ExchangeRate[]
  uoms               Uom[]
  uomConversions     UomConversion[]
  itemCategories     ItemCategory[]
  itemGroups         ItemGroup[]
  brands             Brand[]
  hsnSacs            HsnSac[]
  items              Item[]
  barcodes           Barcode[]
  customerCategories CustomerCategory[]
  customers          Customer[]
  vendorCategories   VendorCategory[]
  vendors            Vendor[]
  
  // HR Masters
  employees          Employee[]
  shifts             Shift[]
  holidays           Holiday[]
  
  // Financial Masters
  accounts           Account[]
  bankAccounts       BankAccount[]
  taxes              Tax[]
  paymentTerms       PaymentTerm[]
  priceLists         PriceList[]
  territories        Territory[]
  
  // Manufacturing Masters
  machines           Machine[]
  workCenters        WorkCenter[]
  operations         Operation[]
  routings           Routing[]
  tools              Tool[]
  qualityParameters  QualityParameter[]
  skills             Skill[]
  batches            Batch[]
  
  // Kitchen Manufacturing Masters
  cabinetTypes      CabinetType[]
  kitchenHardware   KitchenHardware[]
  kitchenFinishes   KitchenFinish[]
  materialGrades    MaterialGrade[]
  kitchenLayouts    KitchenLayout[]
  installationTypes InstallationType[]
  kitchenAppliances KitchenAppliance[]

  // System Masters
  roles             Role[]
  users             User[]
  documentTypes     DocumentType[]
  numberSeries      NumberSeries[]
  
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@map("core_companies")
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  cityId    String?
  city      City?    @relation(fields: [cityId], references: [id])
  address   String?
  isActive  Boolean  @default(true)
  
  departments Department[]
  plants      Plant[]
  warehouses  Warehouse[]
  employees   Employee[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("core_branches")
}

model Department {
  id        String   @id @default(uuid())
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  isActive  Boolean  @default(true)
  
  employees Employee[]
  workCenters WorkCenter[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, companyId])
  @@map("core_departments")
}

model Designation {
  id        String   @id @default(uuid())
  code      String
  name      String
  level     Int?
  grade     String?
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  isActive  Boolean  @default(true)
  
  employees Employee[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code, companyId])
  @@map("core_designations")
}

model CostCenter {
  id        String   @id @default(uuid())
  code      String
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  isActive  Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code, companyId])
  @@map("core_cost_centers")
}

model Plant {
  id        String   @id @default(uuid())
  code      String
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  isActive  Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code, companyId])
  @@map("core_plants")
}

model Warehouse {
  id        String   @id @default(uuid())
  code      String
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  address   String?
  isActive  Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code, companyId])
  @@map("core_warehouses")
}

model ExchangeRate {
  id             String   @id @default(uuid())
  fromCurrencyId String
  fromCurrency   Currency @relation("FromCurrency", fields: [fromCurrencyId], references: [id])
  toCurrencyId   String
  toCurrency     Currency @relation("ToCurrency", fields: [toCurrencyId], references: [id])
  rate           Float
  effectiveDate  DateTime
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id])
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("core_exchange_rates")
}

// --- Foundation Masters ---

model Currency {
  id            String    @id @default(uuid())
  code          String    @unique
  name          String
  symbol        String
  symbolNative  String?
  decimalDigits Int       @default(2)
  rounding      Float     @default(0)
  isActive      Boolean   @default(true)
  
  baseCompanies     Company[] @relation("BaseCurrency")
  fromExchangeRates ExchangeRate[] @relation("FromCurrency")
  toExchangeRates   ExchangeRate[] @relation("ToCurrency")
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("core_currencies")
}

model Uom {
  id        String   @id @default(uuid())
  code      String
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  isActive  Boolean  @default(true)
  
  conversionsFrom UomConversion[] @relation("FromUom")
  conversionsTo   UomConversion[] @relation("ToUom")
  items           Item[]
  workCenters     WorkCenter[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code, companyId])
  @@map("core_uoms")
}

model UomConversion {
  id        String   @id @default(uuid())
  fromUomId String
  fromUom   Uom      @relation("FromUom", fields: [fromUomId], references: [id])
  toUomId   String
  toUom     Uom      @relation("ToUom", fields: [toUomId], references: [id])
  factor    Float
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("core_uom_conversions")
}

model ItemCategory {
  id        String   @id @default(uuid())
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  isActive  Boolean  @default(true)
  
  groups    ItemGroup[]
  items     Item[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, companyId])
  @@map("core_item_categories")
}

model ItemGroup {
  id             String       @id @default(uuid())
  name           String
  categoryId     String
  category       ItemCategory @relation(fields: [categoryId], references: [id])
  companyId      String
  company        Company      @relation(fields: [companyId], references: [id])
  isActive       Boolean      @default(true)
  
  items          Item[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([name, companyId])
  @@map("core_item_groups")
}

model Brand {
  id        String   @id @default(uuid())
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  isActive  Boolean  @default(true)
  items     Item[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, companyId])
  @@map("core_brands")
}

model HsnSac {
  id          String   @id @default(uuid())
  code        String
  description String?
  gstPercentage Float    @default(0)
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  isActive    Boolean  @default(true)
  items       Item[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([code, companyId])
  @@map("core_hsn_sac")
}

model Item {
  id            String       @id @default(uuid())
  code          String
  name          String
  description   String?
  itemType      String       // RAW_MATERIAL, FINISHED_GOODS, etc.
  categoryId    String?
  category      ItemCategory? @relation(fields: [categoryId], references: [id])
  groupId       String?
  group         ItemGroup?    @relation(fields: [groupId], references: [id])
  uomId         String
  uom           Uom           @relation(fields: [uomId], references: [id])
  brandId       String?
  brand         Brand?        @relation(fields: [brandId], references: [id])
  hsnSacId      String?
  hsnSac        HsnSac?       @relation(fields: [hsnSacId], references: [id])
  sku           String?
  purchasePrice Float?       @default(0)
  sellingPrice  Float?       @default(0)
  costPrice     Float?       @default(0)
  minStockLevel Float?       @default(0)
  maxStockLevel Float?       @default(0)
  reorderLevel  Float?       @default(0)
  reorderQuantity Float?     @default(0)
  isStockable   Boolean      @default(true)
  isSellable    Boolean      @default(true)
  isPurchasable Boolean      @default(true)
  companyId     String
  company       Company      @relation(fields: [companyId], references: [id])
  isActive      Boolean      @default(true)
  barcodes      Barcode[]
  routings      Routing[]
  batches       Batch[]
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([code, companyId])
  @@map("core_items")
}

model Barcode {
  id        String   @id @default(uuid())
  code      String
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id])
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  isActive  Boolean  @default(true)
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([code, companyId])
  @@map("core_barcodes")
}

// --- Stakeholder Masters ---

model CustomerCategory {
  id          String   @id @default(uuid())
  code        String
  name        String
  description String?
  color       String?  @default("#3B82F6")
  icon        String?
  level       String?  @default("Primary")
  classification String? @default("Standard")
  status      String   @default("Active")
  
  // Nested JSON fields for consistency with UI
  criteria    Json?    // minRevenue, minOrders, etc.
  benefits    Json?    // discountPercent, creditLimit, etc.
  terms       Json?    // paymentTerms, deliveryPriority, etc.
  targets     Json?    // revenueTarget, growthTarget, etc.
  metrics     Json?    // customerCount, totalRevenue, etc.

  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  
  customers   Customer[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([code, companyId])
  @@map("crm_customer_categories")
}

model Customer {
  id            String   @id @default(uuid())
  customerCode  String
  customerName  String
  customerType  String   @default("business") // individual, business, government
  status        String   @default("active")
  
  categoryId    String?
  category      CustomerCategory? @relation(fields: [categoryId], references: [id])
  
  contactPerson String?
  email         String?
  phone         String?
  mobile        String?
  website       String?

  // Nested JSON fields for consistency with UI
  address       Json?    // line1, city, state, etc.
  billingAddress Json?
  taxInfo       Json?    // taxId, vatNumber, etc.
  creditInfo    Json?    // creditLimit, paymentTerms, etc.
  pricing       Json?    // priceList, discountPercentage, etc.
  salesInfo     Json?    // salesRep, totalSales, etc.

  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([customerCode, companyId])
  @@map("crm_customers")
}

model VendorCategory {
  id          String   @id @default(uuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  
  vendors     Vendor[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, companyId])
  @@map("proc_vendor_categories")
}

model Vendor {
  id            String   @id @default(uuid())
  vendorCode    String
  vendorName    String
  vendorType    String   @default("supplier")
  status        String   @default("active")
  
  categoryId    String?
  category      VendorCategory? @relation(fields: [categoryId], references: [id])
  
  contactPerson String?
  email         String?
  phone         String?
  mobile        String?
  website       String?

  // Nested JSON fields for consistency with UI
  address       Json?
  taxInfo       Json?
  paymentInfo   Json?
  qualifications Json?   // certifications, licenses, etc.
  supplierInfo  Json?   // leadTime, minimumOrderValue, etc.
  performance   Json?   // onTimeDelivery, qualityScore, etc.

  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([vendorCode, companyId])
  @@map("proc_vendors")
}

// --- HR Masters ---

model Employee {
  id              String      @id @default(uuid())
  employeeCode    String
  firstName       String
  lastName        String
  email           String?
  phone           String?
  designationId   String?
  designation     Designation? @relation(fields: [designationId], references: [id])
  departmentId    String?
  department      Department?  @relation(fields: [departmentId], references: [id])
  branchId        String?
  branch          Branch?      @relation(fields: [branchId], references: [id])
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id])
  joiningDate     DateTime?
  status          String       @default("Active") // Active, Inactive, Terminated, Resigned
  isActive        Boolean      @default(true)
  user            User?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([employeeCode, companyId])
  @@map("hr_employees")
}

model Shift {
  id        String   @id @default(uuid())
  code      String
  name      String
  startTime String?  // e.g., "09:00"
  endTime   String?  // e.g., "18:00"
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code, companyId])
  @@map("hr_shifts")
}

model Holiday {
  id          String   @id @default(uuid())
  date        DateTime
  name        String
  holidayType String   @default("Public") // Public, Company
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date, companyId])
  @@map("hr_holidays")
}

// --- Financial Masters ---

model Account {
  id               String   @id @default(uuid())
  accountCode      String
  accountName      String
  parentId         String?
  parent           Account?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children         Account[] @relation("AccountHierarchy")
  level            Int      @default(1)
  accountType      String   // asset, liability, equity, revenue, expense
  accountSubType   String?
  status           String   @default("active")
  description      String?
  isControlAccount Boolean  @default(false)
  allowPosting     Boolean  @default(true)
  currency         String   @default("INR")
  
  // JSON fields for specific settings
  taxConfiguration Json?    // taxable, defaultTaxCode, etc.
  reportingSettings Json?   // includeInBalanceSheet, etc.
  balanceInfo      Json?    // openingBalance, currentBalance, etc.
  restrictions     Json?    // department, costCenter, etc.
  integration      Json?    // bankAccount, externalCode, etc.

  companyId        String
  company          Company  @relation(fields: [companyId], references: [id])

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([accountCode, companyId])
  @@map("fin_accounts")
}

model BankAccount {
  id                String   @id @default(uuid())
  bankName          String
  branchName        String?
  accountNumber     String
  accountType       String   // savings, current, cc, od
  ifscCode          String
  swiftCode         String?
  micrCode          String?
  accountHolderName String
  currency          String   @default("INR")
  status            String   @default("active")
  isPrimary         Boolean  @default(false)

  contactDetails    Json?    // branchAddress, city, state, pincode, etc.
  bankingDetails    Json?    // openingBalance, currentBalance, overdraftLimit, etc.
  onlineAccess      Json?    // internetBanking, netbankingId, upiId, etc.

  companyId         String
  company           Company  @relation(fields: [companyId], references: [id])

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([accountNumber, companyId])
  @@map("fin_bank_accounts")
}

model Tax {
  id            String   @id @default(uuid())
  taxCode       String
  taxName       String
  taxType       String   // sales, purchase, service, vat, gst, etc.
  status        String   @default("active")
  description   String?
  rate          Float
  rateType      String   @default("percentage") // percentage, fixed
  
  taxComponents Json?    // Array of {componentName, rate, account}
  applicability Json?    // applicableOn, territory, etc.
  calculation   Json?    // method, roundingMethod, etc.
  compliance    Json?    // reportingRequired, filingFrequency, etc.
  validity      Json?    // effectiveFrom, effectiveTo, isDefault
  accounting    Json?    // salesTaxAccount, purchaseTaxAccount, etc.

  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([taxCode, companyId])
  @@map("fin_taxes")
}

model PaymentTerm {
  id            String   @id @default(uuid())
  termCode      String
  termName      String
  description   String?
  paymentType   String   // immediate, days, date, installment
  dueDays       Int?
  dueDate       Int?     // Day of month
  
  installments  Json?    // Array of {installmentNumber, percentage, daysAfter}
  discountTerms Json?    // {discountPercentage, discountDays}
  penaltyTerms  Json?    // {penaltyPercentage, gracePeriodDays}
  
  applicableTo  String   @default("both") // purchase, sales, both
  isDefault     Boolean  @default(false)
  status        String   @default("active")

  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([termCode, companyId])
  @@map("fin_payment_terms")
}

model PriceList {
  id               String   @id @default(uuid())
  priceListCode    String
  priceListName    String
  description      String?
  effectiveFrom    DateTime
  effectiveTo      DateTime?
  customerCategory String   @default("all")
  applicableFor    String   @default("sales") // sales, purchase
  pricingMethod    String   @default("fixed") // fixed, markup, markdown, formula
  markupPercentage Float?
  currency         String   @default("INR")
  includeTax       Boolean  @default(false)
  isDefault        Boolean  @default(false)
  status           String   @default("active")

  items            PriceListItem[]

  companyId        String
  company          Company  @relation(fields: [companyId], references: [id])

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([priceListCode, companyId])
  @@map("fin_price_lists")
}

model PriceListItem {
  id          String   @id @default(uuid())
  itemCode    String
  itemName    String
  price       Float
  minQty      Float?
  maxQty      Float?

  priceListId String
  priceList   PriceList @relation(fields: [priceListId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("fin_price_list_items")
}

// -----------------------------------------
// Manufacturing Masters
// -----------------------------------------

model Machine {
  id              String   @id @default(uuid())
  machineCode     String
  machineName     String
  description     String?
  category        String?  // cutting, drilling, etc.
  manufacturer    String?
  model           String?
  serialNumber    String?
  
  // Specifications
  capacity        String?
  power           String?
  dimensions      String?
  weight          Float?
  
  // Location
  plantId         String?
  workCenterId    String?
  workCenter      WorkCenter? @relation(fields: [workCenterId], references: [id])
  
  // Acquisition
  purchaseDate    DateTime?
  purchaseCost    Float?
  warrantyExpiry  DateTime?
  
  // Performance
  efficiency      Float    @default(0)
  utilizationRate Float    @default(0)
  
  status          String   @default("operational") // operational, maintenance, breakdown, idle
  
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([machineCode, companyId])
  @@map("mfg_machines")
}

model WorkCenter {
  id            String   @id @default(uuid())
  code          String
  name          String
  type          String?  // Production, Assembly, etc.
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  location      String?
  
  // Capacity
  dailyCapacity Float?
  uomId         String?
  uom           Uom?     @relation(fields: [uomId], references: [id])
  efficiency    Float    @default(0)
  
  status        String   @default("Active") // Active, Inactive, Maintenance
  
  machines      Machine[]
  operations    Operation[]
  routingSteps  RoutingStep[]

  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([code, companyId])
  @@map("mfg_work_centers")
}

model Operation {
  id            String   @id @default(uuid())
  code          String
  name          String
  description   String?
  
  workCenterId  String
  workCenter    WorkCenter @relation(fields: [workCenterId], references: [id])
  
  setupTime     Float?   // in minutes
  runTime       Float?   // in minutes
  
  routingSteps  RoutingStep[]

  companyId     String
  company       Company    @relation(fields: [companyId], references: [id])
  
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([code, companyId])
  @@map("mfg_operations")
}

model Routing {
  id            String   @id @default(uuid())
  code          String
  name          String
  itemId        String
  item          Item     @relation(fields: [itemId], references: [id])
  
  isDefault     Boolean  @default(false)
  
  steps         RoutingStep[]

  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

