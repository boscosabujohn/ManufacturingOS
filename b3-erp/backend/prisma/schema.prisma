  calculatedAt        DateTime?
  calculatedBy        String?
  approvedAt          DateTime?
  approvedBy          String?

  // Payment
  paymentDate         DateTime?
  paymentMode         String?  // bank_transfer, cheque, cash
  paymentReference    String?
