  leadSource        String?
  campaignId        String?
  campaign          CrmCampaign? @relation(fields: [campaignId], references: [id])

  // Assignment
  ownerId           String?
  ownerName         String?
  teamId            String?

  // Win/Loss Analysis
  winReason         String?
  lossReason        String?
  competitor        String?

  // Products/Services
  products          Json?    // Array of {productId, name, quantity, price}

  // Metadata
  tags              String[]
  customFields      Json?
  notes             String?

  companyId         String

  // Relations
  activities        CrmActivity[]
  quotes            CrmQuote[]
  contracts         CrmContract[]

  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([opportunityNumber, companyId])
  @@map("crm_opportunities")
