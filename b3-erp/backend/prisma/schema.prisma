  status              String   @default("active") // active, inactive, not_applicable, pending_review
  complianceStatus    String   @default("pending") // compliant, non_compliant, pending, partially_compliant
  lastComplianceDate  DateTime?
  nextDueDate         DateTime?

  // Risk assessment
  riskLevel           String   @default("medium") // low, medium, high, critical
  penaltyType         String?  // fine, imprisonment, both, license_cancellation
  penaltyAmount       Decimal?
  penaltyDescription  String?

  // Responsibility
  responsibleRole     String?
  responsibleDepartment String?
