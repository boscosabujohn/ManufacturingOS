// ============================================
// PAYROLL MANAGEMENT MODELS
// ============================================

// Salary Component Types (Earnings/Deductions)
model SalaryComponent {
  id              String   @id @default(uuid())
  code            String
  name            String
  type            String   // Earning, Deduction, Reimbursement
  category        String   // Basic, Allowance, Bonus, Statutory, Other
  calculationType String   // Fixed, Percentage, Formula
  calculationBase String?  // BasicSalary, GrossSalary, CTC, etc.
  percentage      Float?
  fixedAmount     Float?
  formula         String?
  taxable         Boolean  @default(true)
  isStatutory     Boolean  @default(false)
  affectsPF       Boolean  @default(false)
  affectsESI      Boolean  @default(false)
  affectsGratuity Boolean  @default(false)
  displayOrder    Int      @default(0)
  isActive        Boolean  @default(true)
  companyId       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  salaryStructures EmployeeSalaryStructure[]

  @@unique([code, companyId])
  @@map("payroll_salary_components")
}

// Employee Salary Structure
model EmployeeSalaryStructure {
  id               String   @id @default(uuid())
  employeeId       String
  componentId      String
  component        SalaryComponent @relation(fields: [componentId], references: [id])
  amount           Float
  percentage       Float?
  effectiveFrom    DateTime
  effectiveTo      DateTime?
  isActive         Boolean  @default(true)
  companyId        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([employeeId, componentId, effectiveFrom, companyId])
  @@map("payroll_employee_salary_structures")
}

// Bonus Types
model BonusType {
  id              String   @id @default(uuid())
  code            String
  name            String
  description     String?
  calculationType String   // Fixed, PercentageOfBasic, PercentageOfGross, PercentageOfCTC, Custom
  defaultPercent  Float?
  defaultAmount   Float?
  frequency       String   // Annual, Quarterly, Monthly, OneTime
  taxable         Boolean  @default(true)
  isStatutory     Boolean  @default(false)  // For statutory bonus under Bonus Act
  minDaysWorked   Int?     // Minimum days worked to be eligible
  isActive        Boolean  @default(true)
  companyId       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bonusCalculations BonusCalculation[]

  @@unique([code, companyId])
  @@map("payroll_bonus_types")
}

// Bonus Calculation/Payment Records
model BonusCalculation {
  id                 String   @id @default(uuid())
  bonusTypeId        String
  bonusType          BonusType @relation(fields: [bonusTypeId], references: [id])
  employeeId         String
  financialYear      String   // e.g., "2024-25"
  period             String?  // For quarterly: Q1, Q2, Q3, Q4
  eligibleDays       Int
  bonusableAmount    Float    // Base amount for calculation
  calculatedAmount   Float    // Calculated bonus amount
  adjustments        Float    @default(0)
  finalAmount        Float    // After adjustments
  taxDeducted        Float    @default(0)
  netAmount          Float    // After tax
  status             String   @default("Draft") // Draft, Approved, Paid, Cancelled
  approvedBy         String?
  approvedAt         DateTime?
  paidOn             DateTime?
  payslipId          String?
  remarks            String?
  companyId          String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([bonusTypeId, employeeId, financialYear, period, companyId])
  @@map("payroll_bonus_calculations")
}

// Incentive Schemes
model IncentiveScheme {
  id                 String   @id @default(uuid())
  code               String
  name               String
  description        String?
  schemeType         String   // Sales, Performance, Production, Attendance, Custom
  calculationMethod  String   // SlabBased, PercentageOfTarget, FixedPerUnit, Custom
  targetField        String?  // Field to measure (salesAmount, units, attendance%)
  slabs              Json?    // Array of slabs with ranges and incentive amounts
  minThreshold       Float?   // Minimum threshold to qualify
  maxCap             Float?   // Maximum incentive cap
  frequency          String   // Monthly, Quarterly, Annual
  applicableTo       String   // All, Department, Designation, Individual
  applicableIds      Json?    // Array of department/designation/employee IDs
  effectiveFrom      DateTime
  effectiveTo        DateTime?
  isActive           Boolean  @default(true)
  companyId          String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  incentivePayments EmployeeIncentive[]

  @@unique([code, companyId])
  @@map("payroll_incentive_schemes")
}

// Employee Incentive Records
model EmployeeIncentive {
  id                 String   @id @default(uuid())
  schemeId           String
  scheme             IncentiveScheme @relation(fields: [schemeId], references: [id])
  employeeId         String
  periodStart        DateTime
  periodEnd          DateTime
  achievedValue      Float    // What the employee achieved
  targetValue        Float?   // What was the target
  achievementPercent Float?   // Achievement percentage
  incentiveAmount    Float    // Calculated incentive
  adjustments        Float    @default(0)
  finalAmount        Float
  status             String   @default("Draft") // Draft, Approved, Paid, Cancelled
  approvedBy         String?
  approvedAt         DateTime?
  paidOn             DateTime?
  payslipId          String?
  remarks            String?
  companyId          String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([schemeId, employeeId, periodStart, companyId])
  @@map("payroll_employee_incentives")
}

// Loan Types
model LoanType {
  id                  String   @id @default(uuid())
  code                String
  name                String
  description         String?
  maxAmount           Float?
  maxTenureMonths     Int?
  interestType        String   // None, Simple, Compound
  defaultInterestRate Float    @default(0)
  processingFeePercent Float   @default(0)
  minServiceMonths    Int      @default(0) // Minimum service to be eligible
  maxLoanMultiplier   Float?   // Max loan as multiple of salary
  requiresGuarantor   Boolean  @default(false)
  documentRequired    Json?    // Array of required document types
  isActive            Boolean  @default(true)
  companyId           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  loans EmployeeLoan[]

  @@unique([code, companyId])
  @@map("payroll_loan_types")
}

// Employee Loans
model EmployeeLoan {
  id                  String   @id @default(uuid())
  loanNumber          String
  loanTypeId          String
  loanType            LoanType @relation(fields: [loanTypeId], references: [id])
  employeeId          String
  requestDate         DateTime @default(now())
  requestedAmount     Float
  approvedAmount      Float?
  interestRate        Float    @default(0)
  tenureMonths        Int
  emiAmount           Float?
  processingFee       Float    @default(0)
  totalRepayable      Float?
  disbursementDate    DateTime?
  repaymentStartDate  DateTime?
  repaymentEndDate    DateTime?
  outstandingBalance  Float?
  paidEMIs            Int      @default(0)
  remainingEMIs       Int?
  status              String   @default("Pending") // Pending, Approved, Rejected, Disbursed, Active, Closed, Defaulted
  requestedBy         String?
  approvedBy          String?
  approvedAt          DateTime?
  rejectionReason     String?
  guarantorId         String?
  documents           Json?    // Uploaded document references
  remarks             String?
  companyId           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  repayments LoanRepayment[]

  @@unique([loanNumber, companyId])
  @@map("payroll_employee_loans")
}

// Loan Repayment/EMI Records
model LoanRepayment {
  id                String   @id @default(uuid())
  loanId            String
  loan              EmployeeLoan @relation(fields: [loanId], references: [id])
  emiNumber         Int
  dueDate           DateTime
  principalAmount   Float
  interestAmount    Float
  emiAmount         Float
  paidAmount        Float    @default(0)
  balanceAfterEMI   Float
  status            String   @default("Pending") // Pending, Deducted, Paid, Skipped, Waived
  deductionDate     DateTime?
  payslipId         String?
  paymentMode       String?  // Salary, Manual, Adjustment
  remarks           String?
  companyId         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([loanId, emiNumber])
  @@map("payroll_loan_repayments")
}

// Salary Advance
model SalaryAdvance {
  id                String   @id @default(uuid())
  advanceNumber     String
  employeeId        String
  requestDate       DateTime @default(now())
  requestedAmount   Float
  approvedAmount    Float?
  purpose           String?
  repaymentMonths   Int      @default(1)
  monthlyDeduction  Float?
  disbursementDate  DateTime?
  status            String   @default("Pending") // Pending, Approved, Rejected, Disbursed, Repaying, Closed
  approvedBy        String?
  approvedAt        DateTime?
  rejectionReason   String?
  paidAmount        Float    @default(0)
  balanceAmount     Float?
  remarks           String?
  companyId         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  recoveries AdvanceRecovery[]

  @@unique([advanceNumber, companyId])
  @@map("payroll_salary_advances")
}

// Advance Recovery Records
model AdvanceRecovery {
  id                String   @id @default(uuid())
  advanceId         String
  advance           SalaryAdvance @relation(fields: [advanceId], references: [id])
  installmentNumber Int
  dueDate           DateTime
  amount            Float
  paidAmount        Float    @default(0)
  balanceAfter      Float
  status            String   @default("Pending") // Pending, Deducted, Paid, Waived
  deductionDate     DateTime?
  payslipId         String?
  remarks           String?
  companyId         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([advanceId, installmentNumber])
  @@map("payroll_advance_recoveries")
}

// Payroll Period (Monthly Processing Period)
model PayrollPeriod {
  id                String   @id @default(uuid())
  periodCode        String   // e.g., "2025-02"
  periodName        String   // e.g., "February 2025"
  year              Int
  month             Int
  startDate         DateTime
  endDate           DateTime
  payDate           DateTime?
  workingDays       Int?
  status            String   @default("Open") // Open, Processing, Locked, Closed
  lockedBy          String?
  lockedAt          DateTime?
  closedBy          String?
  closedAt          DateTime?
  companyId         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  payrollRuns PayrollRun[]

  @@unique([periodCode, companyId])
  @@map("payroll_periods")
}

// Payroll Run (Batch Processing)
model PayrollRun {
  id                String   @id @default(uuid())
  runCode           String
  periodId          String
  period            PayrollPeriod @relation(fields: [periodId], references: [id])
  runType           String   // Regular, Supplementary, Arrear, FinalSettlement
  processedCount    Int      @default(0)
  totalGross        Float    @default(0)
  totalDeductions   Float    @default(0)
  totalNet          Float    @default(0)
  totalPF           Float    @default(0)
  totalESI          Float    @default(0)
  totalTDS          Float    @default(0)
  status            String   @default("Draft") // Draft, Processing, Completed, Approved, Paid, Cancelled
  processedBy       String?
  processedAt       DateTime?
  approvedBy        String?
  approvedAt        DateTime?
  paidBy            String?
  paidAt            DateTime?
  remarks           String?
  companyId         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  payslips PaySlip[]

  @@unique([runCode, companyId])
  @@map("payroll_runs")
}

// Pay Slip
model PaySlip {
  id                  String   @id @default(uuid())
  payslipNumber       String
  payrollRunId        String
  payrollRun          PayrollRun @relation(fields: [payrollRunId], references: [id])
  employeeId          String
  employeeCode        String
  employeeName        String
  departmentId        String?
  departmentName      String?
  designationId       String?
  designationName     String?
  periodMonth         Int
  periodYear          Int
  workingDays         Int
  presentDays         Float
  lopDays             Float    @default(0)
  paidDays            Float

  // Earnings Breakdown (stored as JSON for flexibility)
  basicSalary         Float    @default(0)
  hra                 Float    @default(0)
  conveyanceAllowance Float    @default(0)
  specialAllowance    Float    @default(0)
  otherEarnings       Float    @default(0)
  earningsBreakdown   Json?    // Detailed component-wise breakdown
  grossEarnings       Float    @default(0)

  // Deductions Breakdown
  pfEmployee          Float    @default(0)
  pfEmployer          Float    @default(0)
  esiEmployee         Float    @default(0)
  esiEmployer         Float    @default(0)
  professionalTax     Float    @default(0)
  tds                 Float    @default(0)
  loanDeductions      Float    @default(0)
  advanceDeductions   Float    @default(0)
  otherDeductions     Float    @default(0)
  deductionsBreakdown Json?    // Detailed component-wise breakdown
  grossDeductions     Float    @default(0)

  netPayable          Float    @default(0)

  // Bank Details
  bankName            String?
  accountNumber       String?
  ifscCode            String?
  paymentMode         String?  // BankTransfer, Cash, Cheque
  paymentStatus       String   @default("Pending") // Pending, Processed, Paid, Failed
  paymentDate         DateTime?
  paymentReference    String?

  status              String   @default("Draft") // Draft, Generated, Approved, Published, Cancelled
  generatedAt         DateTime?
  approvedBy          String?
  approvedAt          DateTime?
  publishedAt         DateTime?
  remarks             String?
  companyId           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([payslipNumber, companyId])
  @@unique([payrollRunId, employeeId])
  @@map("payroll_payslips")
}

// Tax Declarations (Form 12BB / Investment Declarations)
model TaxDeclaration {
  id                  String   @id @default(uuid())
  employeeId          String
  financialYear       String   // e.g., "2024-25"
  declarationType     String   // Provisional, Actual

  // Section 80C (Max 1.5L)
  section80C_PPF      Float    @default(0)
  section80C_ELSS     Float    @default(0)
  section80C_LIC      Float    @default(0)
  section80C_NSC      Float    @default(0)
  section80C_HomeLoan Float    @default(0)
  section80C_TuitionFee Float  @default(0)
  section80C_FD       Float    @default(0)
  section80C_Other    Float    @default(0)
  section80C_Total    Float    @default(0)

  // Section 80D (Medical Insurance)
  section80D_Self     Float    @default(0)
  section80D_Parents  Float    @default(0)
  section80D_Total    Float    @default(0)

  // Other Sections
  section80E_Education Float   @default(0)
  section80G_Donation  Float   @default(0)
  section80TTA_Savings Float   @default(0)
  section24_HomeLoan   Float   @default(0)
  nps_80CCD1B         Float    @default(0)

  // HRA Exemption
  hraExemption        Float    @default(0)
  rentPaid            Float    @default(0)
  landlordPAN         String?

  // LTA
  ltaClaimed          Float    @default(0)

  // Regime Selection
  taxRegime           String   @default("Old") // Old, New

  // Calculated Values
  totalDeductions     Float    @default(0)
  taxableIncome       Float?
  estimatedTax        Float?
  monthlyTDS          Float?

  status              String   @default("Draft") // Draft, Submitted, Verified, Approved, Locked
  submittedAt         DateTime?
  verifiedBy          String?
  verifiedAt          DateTime?
  approvedBy          String?
  approvedAt          DateTime?
  proofsSubmitted     Boolean  @default(false)
  documents           Json?    // Uploaded proof documents
  remarks             String?
  companyId           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([employeeId, financialYear, declarationType, companyId])
  @@map("payroll_tax_declarations")
}

// Provident Fund Contribution
model PFContribution {
