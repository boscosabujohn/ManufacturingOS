// --- Support Analytics ---

model SupportAnalyticsSnapshot {
  id                  String   @id @default(uuid())
  snapshotDate        DateTime
  periodType          String   // daily, weekly, monthly
  
  // Ticket Metrics
  ticketsCreated      Int      @default(0)
  ticketsResolved     Int      @default(0)
  ticketsClosed       Int      @default(0)
  ticketsReopened     Int      @default(0)
  ticketsEscalated    Int      @default(0)
  
  // Backlog
  openTickets         Int      @default(0)
  pendingTickets      Int      @default(0)
  overdueTickets      Int      @default(0)
  
  // SLA
  slaCompliance       Decimal? @db.Decimal(5, 2)
  firstResponseBreaches Int    @default(0)
  resolutionBreaches  Int      @default(0)
  
  // Response Times
  avgFirstResponseMinutes Int?
  avgResolutionMinutes Int?
  medianResolutionMinutes Int?
  
  // Satisfaction
  avgCsatScore        Decimal? @db.Decimal(3, 2)
  npsScore            Int?
  csatResponseCount   Int      @default(0)
  
  // Channel Breakdown
  byChannel           Json?    // {email: count, chat: count, ...}
  byPriority          Json?    // {low: count, medium: count, ...}
  byCategory          Json?    // {category1: count, ...}
  
  // Agent Metrics
  avgTicketsPerAgent  Decimal? @db.Decimal(6, 2)
  agentUtilization    Decimal? @db.Decimal(5, 2)
  
  companyId           String
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([snapshotDate, periodType, companyId])
  @@map("support_analytics_snapshots")
}

// --- Support Module Settings ---

model SupportModuleSettings {
  id                  String   @id @default(uuid())
  companyId           String   @unique
  
  // Code Prefixes
  ticketPrefix        String   @default("TKT")
  incidentPrefix      String   @default("INC")
  problemPrefix       String   @default("PRB")
  changePrefix        String   @default("CHG")
  assetPrefix         String   @default("AST")
  knownErrorPrefix    String   @default("KE")
  rcaPrefix           String   @default("RCA")
  
  // Ticket Settings
  autoAssignEnabled   Boolean  @default(false)
  assignmentMethod    String   @default("round_robin") // round_robin, load_balanced, skill_based, manual
  reopenWindow        Int      @default(48) // Hours
  autoCloseResolved   Boolean  @default(true)
  autoCloseDays       Int      @default(7)
  
  // SLA Settings
  defaultSlaId        String?
  slaTrackingEnabled  Boolean  @default(true)
  slaBusinessHoursOnly Boolean @default(true)
  
  // Notification Settings
  notifyOnNewTicket   Boolean  @default(true)
  notifyOnAssignment  Boolean  @default(true)
  notifyOnEscalation  Boolean  @default(true)
  notifyOnResolution  Boolean  @default(true)
  
  // Customer Portal
  customerPortalEnabled Boolean @default(true)
  allowCustomerReopen Boolean  @default(true)
  allowAttachments    Boolean  @default(true)
  maxAttachmentSize   Int      @default(10) // MB
  
  // CSAT
  csatEnabled         Boolean  @default(true)
  csatSendOnClosure   Boolean  @default(true)
  csatReminderEnabled Boolean  @default(false)
  csatReminderDays    Int      @default(3)
  
  // AI Features
  aiSuggestionsEnabled Boolean @default(false)
  aiAutoCategorizationEnabled Boolean @default(false)
  aiSentimentAnalysisEnabled Boolean @default(false)
  
  // Integration
  emailIntegrationEnabled Boolean @default(false)
  emailToTicketEnabled Boolean @default(false)
  chatbotEnabled      Boolean  @default(false)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("support_module_settings")
}

// ==============================================
// REPORTS & ANALYTICS MODULE
// ==============================================

// Report Templates - predefined report definitions
model ReportTemplate {
  id                  String   @id @default(uuid())
  templateCode        String
  templateName        String
  description         String?

  // Classification
  category            String   // finance, sales, inventory, hr, production, quality
  subCategory         String?  // balance_sheet, pl, aging, etc.
  reportType          String   // summary, detail, comparison, trend, dashboard

  // Configuration
  dataSource          String   // Which module/entity to pull data from
  defaultFilters      Json?    // Default filter configuration
  availableFilters    Json?    // Which filters can be applied
  columns             Json?    // Column configuration
  chartConfig         Json?    // Chart/visualization configuration

  // Query
  queryTemplate       String?  // SQL or aggregation template
  aggregations        Json?    // Aggregation definitions

  // Output
  outputFormats       String[] // pdf, excel, csv, html
  defaultFormat       String   @default("pdf")

  // Access
  isPublic            Boolean  @default(true)
  requiredPermissions String[]

  isActive            Boolean  @default(true)
  companyId           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  savedReports        SavedReport[]
  schedules           ReportSchedule[]

  @@unique([templateCode, companyId])
  @@map("report_templates")
}

// Saved Reports - user's saved report configurations
model SavedReport {
  id                  String   @id @default(uuid())
  reportCode          String
  reportName          String
  description         String?

  // Template Reference
  templateId          String?
  template            ReportTemplate? @relation(fields: [templateId], references: [id])

  // Configuration
  category            String   // finance, sales, inventory, hr, production, quality
  filters             Json?    // User's filter selections
  columns             Json?    // Column customizations
  chartConfig         Json?    // Chart customizations
  sortOrder           Json?    // Sort configuration
  groupBy             String[]

  // Date Range
  dateRangeType       String?  // today, week, month, quarter, year, custom
  dateFrom            DateTime?
  dateTo              DateTime?
  relativePeriod      String?  // last_7_days, last_30_days, etc.

  // Output
  outputFormat        String   @default("pdf")

  // Ownership
  createdById         String
  createdByName       String?
  isShared            Boolean  @default(false)
  sharedWith          String[] // User IDs or 'all'

  // Usage
  lastRunAt           DateTime?
  runCount            Int      @default(0)

  isFavorite          Boolean  @default(false)
  isActive            Boolean  @default(true)
  companyId           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  schedules           ReportSchedule[]
  executions          ReportExecution[]

  @@unique([reportCode, companyId])
  @@map("saved_reports")
}

// Report Schedules - automated report generation
model ReportSchedule {
  id                  String   @id @default(uuid())
  scheduleCode        String
  scheduleName        String
  description         String?

  // Report Reference
  savedReportId       String?
  savedReport         SavedReport? @relation(fields: [savedReportId], references: [id])
  templateId          String?
  template            ReportTemplate? @relation(fields: [templateId], references: [id])

  // Schedule Configuration
  frequency           String   // daily, weekly, monthly, quarterly, yearly
  cronExpression      String?  // For custom schedules
  dayOfWeek           Int?     // 0-6 for weekly
  dayOfMonth          Int?     // 1-31 for monthly
  hour                Int      @default(8)
  minute              Int      @default(0)
  timezone            String   @default("UTC")

  // Date Range
  reportPeriod        String?  // previous_day, previous_week, previous_month, mtd, ytd

  // Delivery
  deliveryMethod      String   @default("email") // email, dashboard, storage
  recipients          Json?    // [{email, name, type}]
  emailSubject        String?
  emailBody           String?
  outputFormat        String   @default("pdf")

  // Storage
  storageLocation     String?
  retentionDays       Int      @default(90)

  // Status
  status              String   @default("active") // active, paused, disabled
  nextRunAt           DateTime?
  lastRunAt           DateTime?
  lastRunStatus       String?  // success, failed, partial
  lastError           String?

  // Stats
  successCount        Int      @default(0)
  failureCount        Int      @default(0)

  isActive            Boolean  @default(true)
  companyId           String
  createdById         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  executions          ReportExecution[]

  @@unique([scheduleCode, companyId])
  @@map("report_schedules")
}

// Report Executions - execution history
model ReportExecution {
  id                  String   @id @default(uuid())
  executionCode       String

  // References
  savedReportId       String?
  savedReport         SavedReport? @relation(fields: [savedReportId], references: [id])
  scheduleId          String?
  schedule            ReportSchedule? @relation(fields: [scheduleId], references: [id])

  // Execution Details
  executionType       String   // manual, scheduled
  status              String   @default("pending") // pending, running, completed, failed
  startedAt           DateTime @default(now())
  completedAt         DateTime?
  durationMs          Int?

  // Parameters
  filters             Json?
  dateFrom            DateTime?
  dateTo              DateTime?
  outputFormat        String?

  // Results
  resultFileUrl       String?
  resultFileName      String?
  resultFileSize      Int?
  recordCount         Int?

  // Error
  errorMessage        String?
  errorDetails        Json?

  // Delivery
  deliveryStatus      String?  // sent, delivered, failed
  deliveredTo         Json?
  deliveredAt         DateTime?

  // Metadata
  executedById        String?
  executedByName      String?
  ipAddress           String?

  companyId           String
  createdAt           DateTime @default(now())

  @@unique([executionCode, companyId])
  @@index([savedReportId])
  @@index([scheduleId])
  @@index([status])
  @@map("report_executions")
}

// Analytics Dashboard - dashboard configurations
model AnalyticsDashboard {
  id                  String   @id @default(uuid())
  dashboardCode       String
  dashboardName       String
  description         String?

  // Classification
  category            String?  // finance, sales, inventory, hr, production, quality, executive

  // Layout
  layout              Json?    // Grid layout configuration
  widgets             Json?    // Widget configurations
  theme               String   @default("default")

  // Refresh
  autoRefresh         Boolean  @default(false)
  refreshInterval     Int?     // seconds

  // Access
  isDefault           Boolean  @default(false)
  isPublic            Boolean  @default(true)
  createdById         String
  createdByName       String?
  sharedWith          String[]

  // Usage
  viewCount           Int      @default(0)
  lastViewedAt        DateTime?

  isFavorite          Boolean  @default(false)
  isActive            Boolean  @default(true)
  companyId           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([dashboardCode, companyId])
  @@map("analytics_dashboards")
}

// KPI Definitions - key performance indicators
model KPIDefinition {
  id                  String   @id @default(uuid())
  kpiCode             String
  kpiName             String
  description         String?

  // Classification
  category            String   // finance, sales, inventory, hr, production, quality
  subCategory         String?

  // Calculation
  formula             String?  // Calculation formula/expression
  dataSource          String   // Source entity/table
  aggregationType     String   // sum, avg, count, min, max, custom
  unit                String?  // %, $, units, hours, etc.

  // Targets
  targetValue         Decimal? @db.Decimal(18, 4)
  targetType          String?  // fixed, dynamic, trend
  warningThreshold    Decimal? @db.Decimal(18, 4)
  criticalThreshold   Decimal? @db.Decimal(18, 4)
  thresholdDirection  String   @default("above") // above, below (which is better)

  // Display
  displayFormat       String?  // number, currency, percent
  decimalPlaces       Int      @default(2)
  chartType           String?  // gauge, trend, sparkline

  // Calculation Period
  periodType          String   @default("monthly") // daily, weekly, monthly, quarterly, yearly

  isActive            Boolean  @default(true)
  companyId           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  values              KPIValue[]

  @@unique([kpiCode, companyId])
  @@map("kpi_definitions")
}

// KPI Values - historical KPI values
model KPIValue {
  id                  String   @id @default(uuid())

  kpiId               String
  kpi                 KPIDefinition @relation(fields: [kpiId], references: [id])

  // Period
  periodType          String   // daily, weekly, monthly, quarterly, yearly
  periodStart         DateTime
  periodEnd           DateTime
  fiscalYear          String?
  fiscalPeriod        String?

  // Value
  actualValue         Decimal  @db.Decimal(18, 4)
  targetValue         Decimal? @db.Decimal(18, 4)
  previousValue       Decimal? @db.Decimal(18, 4)
  variance            Decimal? @db.Decimal(18, 4)
  variancePercent     Decimal? @db.Decimal(8, 4)

  // Status
  status              String?  // on_track, warning, critical, exceeded
  trend               String?  // up, down, flat
  trendPercent        Decimal? @db.Decimal(8, 4)

  // Breakdown
  breakdown           Json?    // Dimensional breakdown of the value

  // Metadata
  calculatedAt        DateTime @default(now())
  dataAsOf            DateTime?

  companyId           String
  createdAt           DateTime @default(now())

  @@unique([kpiId, periodType, periodStart, companyId])
  @@index([kpiId])
  @@index([periodStart])
  @@map("kpi_values")
}

// Report Favorites
model ReportFavorite {
  id                  String   @id @default(uuid())

  userId              String
  userName            String?

  // Reference (one of these)
  savedReportId       String?
  dashboardId         String?
  templateId          String?

  displayOrder        Int      @default(0)

  companyId           String
  createdAt           DateTime @default(now())

  @@unique([userId, savedReportId, companyId])
  @@unique([userId, dashboardId, companyId])
  @@unique([userId, templateId, companyId])
  @@map("report_favorites")
}

