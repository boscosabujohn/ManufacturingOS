// Payroll Settings
model PayrollSettings {
  id                  String   @id @default(uuid())

  // PF Settings
  pfEnabled           Boolean  @default(true)
  pfEmployeePercent   Float    @default(12)
  pfEmployerPercent   Float    @default(12)
  pfWageCeiling       Float    @default(15000)
  pfAdminPercent      Float    @default(0.5)
  pfEdliPercent       Float    @default(0.5)

  // ESI Settings
  esiEnabled          Boolean  @default(true)
  esiEmployeePercent  Float    @default(0.75)
  esiEmployerPercent  Float    @default(3.25)
  esiWageCeiling      Float    @default(21000)

  // Professional Tax
  ptEnabled           Boolean  @default(true)
  ptSlabs             Json?    // State-wise PT slabs

  // LWF Settings
  lwfEnabled          Boolean  @default(false)
  lwfEmployeeAmount   Float    @default(0)
  lwfEmployerAmount   Float    @default(0)

